---
interface Props {
  name: string;
  title: string;
  subtitle: string;
  skills: string[];
  githubUrl: string;
}

const { name, title, subtitle, skills, githubUrl } = Astro.props;
---

<section class="hero-section py-20 md:py-32">
  <div class="container mx-auto text-center">
    <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-4">
      {name}
    </h1>
    <h2 class="text-xl md:text-2xl text-primary-600 font-semibold mb-4">
      {title}
    </h2>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8 leading-relaxed">
      {subtitle}
    </p>
    <div class="flex flex-wrap justify-center gap-3 mb-10">
      {skills.map((skill) => (
        <span class="px-4 py-2 bg-gray-100 text-gray-800 rounded-full text-sm font-medium">
          {skill}
        </span>
      ))}
    </div>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#projects"
        class="px-8 py-3 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors"
      >
        Ver Proyectos
      </a>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="px-8 py-3 border-2 border-gray-300 text-gray-700 rounded-lg font-medium hover:border-gray-400 transition-colors"
      >
        GitHub
      </a>
    </div>
  </div>
</section>