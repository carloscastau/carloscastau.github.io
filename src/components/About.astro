---
interface Props {
  bio: string;
  skills: {
    ml: string[];
    mlops: string[];
    cloud: string[];
    leadership: string[];
  };
}

const { bio, skills } = Astro.props;
---

<section id="about" class="about-section py-20 bg-white">
  <div class="container mx-auto">
    <h2 class="text-3xl font-bold text-gray-900 mb-8">Sobre Mí</h2>
    <div class="max-w-3xl">
      <p class="text-lg text-gray-600 leading-relaxed mb-8">
        {bio}
      </p>

      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Machine Learning</h3>
          <div class="flex flex-wrap gap-2">
            {skills.ml.map((skill) => (
              <span class="px-3 py-1 bg-blue-50 text-blue-700 rounded-full text-sm">
                {skill}
              </span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">MLOps & Cloud</h3>
          <div class="flex flex-wrap gap-2">
            {skills.mlops.map((skill) => (
              <span class="px-3 py-1 bg-green-50 text-green-700 rounded-full text-sm">
                {skill}
              </span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Cloud & Infra</h3>
          <div class="flex flex-wrap gap-2">
            {skills.cloud.map((skill) => (
              <span class="px-3 py-1 bg-purple-50 text-purple-700 rounded-full text-sm">
                {skill}
              </span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Liderazgo</h3>
          <div class="flex flex-wrap gap-2">
            {skills.leadership.map((skill) => (
              <span class="px-3 py-1 bg-orange-50 text-orange-700 rounded-full text-sm">
                {skill}
              </span>
            ))}
          </div>
        </div>
      </div>
  </div>
</section>